# ── PostgreSQL ──────────────────────────────────────────────────────
POSTGRES_DB=vault
POSTGRES_USER=vault
POSTGRES_PASSWORD=changeme_strong_password

# ── Application DB URL (must match above) ───────────────────────────
DATABASE_URL=postgresql+asyncpg://vault:changeme_strong_password@postgres:5432/vault

# ── Redis ───────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Security ────────────────────────────────────────────────────────
# JWT signing key (min 32 chars)
JWT_SECRET=changeme_32_char_jwt_secret_key_here
# AES-256-GCM key for credential encryption (exactly 32 bytes, base64 encoded)
CREDENTIAL_ENCRYPT_KEY=changeme_32_byte_key_for_aes256_gcm

# ── E-Hentai limits ─────────────────────────────────────────────────
EH_MAX_CONCURRENCY=2
EH_REQUEST_TIMEOUT=30
EH_ACQUIRE_TIMEOUT=60

# ── Single-user login password ──────────────────────────────────────
VAULT_PASSWORD=changeme_strong_password

# ── AI Tagging (disabled until Phase 6) ─────────────────────────────
TAG_MODEL_ENABLED=false

# ── Nginx port ──────────────────────────────────────────────────────
HTTP_PORT=80
